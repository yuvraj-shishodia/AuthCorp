# ============================================================
# AuthCorp .env.local — Development / Demo Setup
# Copy this file to .env.local in the project root.
# ============================================================

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ── Security (REQUIRED — change these values) ──────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_64_char_random_string_abcdef1234567890abcdef1234567890abcdef
ENCRYPTION_KEY=change_me_32char_encryption_key!
SESSION_SECRET=change_me_to_any_long_random_string_here

# ── Google OAuth (free — console.cloud.google.com) ─────────
# 1. Create project → APIs & Services → Credentials
# 2. OAuth 2.0 Client ID → Web application
# 3. Authorized origins: http://localhost:3000
# 4. Authorized redirect URIs: http://localhost:3000/api/auth/google
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# ── OpenAI API (free $5 credit — platform.openai.com) ──────
# 1. Sign up → API Keys → Create new secret key
# Uses gpt-3.5-turbo — very cheap, ~$0.002 per 1k tokens
OPENAI_API_KEY=sk-your_openai_key_here

# ── Blockchain / Infura (free tier — infura.io) ─────────────
# 1. Sign up → Create project → Copy Project ID
# Replace YOUR_INFURA_PROJECT_ID below:
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID

# ── Database (PostgreSQL — optional for demo) ───────────────
# For local demo without Docker: leave DATABASE_URL commented out
# The app uses in-memory mock data when DB is not connected.
# To use Docker: run "docker-compose up postgres redis"
# DATABASE_URL=postgresql://authcorp_user:authcorp_pass@localhost:5432/authcorp
DB_HOST=localhost
DB_PORT=5432
DB_NAME=authcorp
DB_USER=authcorp_user
DB_PASSWORD=authcorp_pass
DB_SSL=false

# ── Redis (optional for demo) ───────────────────────────────
# For Docker: run "docker-compose up redis"
# REDIS_URL=redis://localhost:6379

# ── Storage (local for demo — no S3 needed) ────────────────
STORAGE_TYPE=local

# ── Feature Flags ───────────────────────────────────────────
ENABLE_BLOCKCHAIN_ANCHORING=true
ENABLE_AR_FORENSICS=true
ENABLE_AI_ASSISTANT=true
ENABLE_REAL_TIME_MONITORING=true
ENABLE_ADVANCED_ANALYTICS=true

# ── Optional (leave blank for demo) ────────────────────────
SENTRY_DSN=
GOOGLE_ANALYTICS_ID=
